{
  "name": "phone-zone",
  "version": "1.1.0",
  "description": "Offline desktop POS for mobile phone retail shops",
  "author": "umair",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --win",
    "test": "vitest run --config vitest.config.test.js",
    "test:watch": "vitest --config vitest.config.test.js",
    "test:coverage": "vitest run --config vitest.config.test.js --coverage"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/exo-2": "^5.2.8",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/share-tech-mono": "^5.2.7",
    "@fontsource/sora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@fontsource/syne": "^5.2.7",
    "better-sqlite3": "^12.10.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "happy-dom": "^20.10.1",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.phonezone.app",
    "productName": "Phone Zone",
    "asar": true,
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "umair"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "build/license.txt"
    },
    "msi": {
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
